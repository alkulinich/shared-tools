  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); branch=$(cd \"$dir\" 2>/dev/null && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo ''); cmd=$(cat \"$dir/.claude/.current-command\" 2>/dev/null | tr -d '\\n'); session_time=$(bash \"$dir/shared/scripts/session-time.sh\" 2>/dev/null); if [ -n \"$session_time\" ]; then time_part=$(printf ' | \\033[1;33m%s\\033[0;34m' \"$session_time\"); else time_part=''; fi; ctx_pct=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); ctx_meter=$(bash \"$dir/shared/scripts/context-meter.sh\" \"$ctx_pct\" 2>/dev/null); if [ -n \"$ctx_meter\" ]; then ctx_part=$(printf ' | %s' \"$ctx_meter\"); else ctx_part=''; fi; pid_section=$(printf '\\033[0;34m[PID: %s | %s%s%s]\\033[0m' \"$PPID\" \"$model\" \"$time_part\" \"$ctx_part\"); if [ -n \"$cmd\" ]; then cmd_section=$(printf '\\033[1;37m > \\033[0;33m%s\\033[0m' \"$cmd\"); else cmd_section=''; fi; if [ -n \"$branch\" ]; then printf \"%s\\033[1;37m > \\033[1;36m%s\\033[1;37m > \\033[0;32m%s%s\\033[0m\" \"$pid_section\" \"$(basename \"$dir\")\" \"$branch\" \"$cmd_section\"; else printf \"%s\\033[1;37m > \\033[1;36m%s%s\\033[0m\" \"$pid_section\" \"$(basename \"$dir\")\" \"$cmd_section\"; fi"
  },
  "hooks": {}
}
